                </div>
            </div>

            <!-- Durum Ayarları -->
            <div class="form-section">
                <div class="section-header">
                    <div class="section-icon" style="background:#f0fdf4;color:#10b981;">
                        <i class="fa-solid fa-toggle-on"></i>
                    </div>
                    <div>
                        <p class="section-title">Durum Ayarları</p>
                        <p class="section-subtitle">Kiralama ve sistem durumu</p>
                    </div>
                </div>
                <div class="section-body" style="padding:16px 24px;">

                    <div class="toggle-row">
                        <div class="toggle-label">
                            <strong>
                                <i class="fa-solid fa-circle-check me-2" style="color:#10b981;"></i>
