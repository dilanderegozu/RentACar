        <!-- ═══ RIGHT COLUMN ═══ -->
        <div class="col-12 col-xl-4">

            <!-- Görsel Yükleme -->
            <div class="form-section">
                <div class="section-header">
                    <div class="section-icon" style="background:#fdf4ff;color:#9333ea;">
