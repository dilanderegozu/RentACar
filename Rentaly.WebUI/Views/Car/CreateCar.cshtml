                <i class="fa-regular fa-floppy-disk"></i> Taslak Kaydet
            </button>
            <button type="submit" class="btn-submit-car" id="submitBtn" onclick="validateCarForm(event)">
                <i class="fa-solid fa-check"></i> Aracı Kaydet
            </button>
