            </div>

            <!-- Canlı Kayıt Özeti -->
            <div class="form-section">
                <div class="section-header">
                    <div class="section-icon" style="background:#e8efff;color:var(--primary);">
                        <i class="fa-solid fa-clipboard-list"></i>
                    </div>
                    <div>
                        <p class="section-title">Kayıt Özeti</p>
                        <p class="section-subtitle">Form dolduğunda güncellenir</p>
                    </div>
                </div>
                <div class="section-body" style="padding:14px 24px;">

                    <div id="sumEmpty" style="text-align:center;padding:10px 0;color:var(--text-muted);font-size:13px;">
                        <i class="fa-regular fa-file-lines" style="font-size:26px;display:block;margin-bottom:8px;opacity:.35;"></i>
                        Formu doldurmaya başlayın…
                    </div>

                    <div class="sum-row" id="sumPlate">
                        <div style="display:flex;justify-content:space-between;">
                            <span style="color:var(--text-muted);">Plaka</span>
                            <strong id="sumPlateVal" style="font-family:'Plus Jakarta Sans',sans-serif;letter-spacing:1px;"></strong>
                        </div>
                    </div>
                    <div class="sum-row" id="sumBrand">
                        <div style="display:flex;justify-content:space-between;">
