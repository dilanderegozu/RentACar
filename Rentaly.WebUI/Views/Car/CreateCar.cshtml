                                    style="position:absolute;right:10px;top:50%;transform:translateY(-50%);background:var(--primary-light);border:none;border-radius:6px;padding:4px 10px;font-size:12px;font-weight:600;color:var(--primary);cursor:pointer;"
                                    onclick="previewUrlImg(document.getElementById('ImageUrl').value)">
