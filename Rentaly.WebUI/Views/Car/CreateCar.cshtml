                            <div class="invalid-feedback" id="transError">
                                <i class="fa-solid fa-circle-exclamation"></i> Vites tipi zorunludur.
                            </div>
                        </div>

                        <!-- Yakıt Tipi Pill Seçici -->
                        <div class="col-12">
