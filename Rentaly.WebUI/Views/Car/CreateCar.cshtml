</form>

@section Scripts {
    <script>
        /* ══════════════════════════════════════════
           CreateCar Page Scripts
        ══════════════════════════════════════════ */

        // ── Model listesi (marka seçimine göre AJAX ile doldurulabilir) ──
        const brandModels = {
            '1': ['3 Serisi','5 Serisi','7 Serisi','X3','X5','X6','M3','M5'],
            '2': ['A Serisi','C Serisi','E Serisi','S Serisi','GLC','GLE','CLA'],
            '3': ['A3','A4','A6','A8','Q3','Q5','Q7','TT','RS6'],
            '4': ['Corolla','Camry','RAV4','Land Cruiser','Yaris','C-HR','Hilux'],
            '5': ['Golf','Passat','Tiguan','Arteon','T-Roc','Touareg','Polo'],
            '6': ['Focus','Mondeo','Explorer','Mustang','Kuga','Edge','Ranger'],
            '7': ['XC40','XC60','XC90','S60','S90','V60','V90'],
            '8': ['i10','i20','i30','Tucson','Santa Fe','Kona','Ioniq 6'],
            '9': ['Model 3','Model Y','Model S','Model X','Cybertruck'],
            '10': ['Clio','Megane','Kadjar','Captur','Talisman','Austral'],
        };

        function loadModels(brandId) {
            const sel = document.getElementById('ModelId');
            sel.innerHTML = '<option value="">— Model Seçin —</option>';

            // Eğer backend'den modeller gelmiyorsa statik listeyi kullan
            const models = brandModels[brandId];
            if (models) {
                models.forEach(m => {
                    const opt = document.createElement('option');
                    opt.value = m; opt.textContent = m;
                    sel.appendChild(opt);
                });
            }

            // AJAX ile yüklemek için:
            // fetch(`/Car/GetModelsByBrand?brandId=${brandId}`)
            //     .then(r => r.json())
            //     .then(data => {
            //         data.forEach(m => {
            //             const opt = document.createElement('option');
            //             opt.value = m.modelId; opt.textContent = m.modelName;
            //             sel.appendChild(opt);
            //         });
            //     });

            updateSummary();
        }

        // ── Plaka önizlemesi ──
        function updatePlatePreview() {
            const val = document.getElementById('PlateNumber').value.trim();
            const wrap = document.getElementById('platePreviewWrap');
            const text = document.getElementById('platePreviewText');
            if (val.length >= 2) {
                wrap.style.display = 'block';
                text.textContent = val;
            } else {
                wrap.style.display = 'none';
            }
            updateSummary();
        }

        // ── VIN karakter sayacı ──
        function updateVinCount() {
            const len = document.getElementById('VIN').value.length;
            document.getElementById('vinCount').textContent = len;
            const errEl = document.getElementById('vinError');
            errEl.style.display = (len > 0 && len !== 17) ? 'flex' : 'none';
        }

        // ── Step counter (+/-) ──
        function adjustCounter(id, delta) {
            const el = document.getElementById(id);
            const min = parseInt(el.min) || 0;
            const max = parseInt(el.max) || 99;
            el.value = Math.max(min, Math.min(max, parseInt(el.value) + delta));
        }

        // ── Fiyat Banner ──
        function updatePriceBanner() {
            const daily   = parseFloat(document.getElementById('DailyPrice').value)   || 0;
            const deposit = parseFloat(document.getElementById('DepositAmount').value) || 0;
            const banner  = document.getElementById('priceBanner');

            if (daily > 0) {
                banner.style.display = 'block';
                document.getElementById('bannerDaily').textContent   = '₺' + daily.toLocaleString('tr-TR');
                document.getElementById('bannerWeekly').textContent  = '₺' + (daily * 7).toLocaleString('tr-TR');
                document.getElementById('bannerMonthly').textContent = '₺' + (daily * 30).toLocaleString('tr-TR');
                document.getElementById('bannerDeposit').textContent = deposit > 0 ? '₺' + deposit.toLocaleString('tr-TR') : '—';
            } else {
                banner.style.display = 'none';
            }
            updateSummary();
        }

        // ── Canlı kayıt özeti ──
        function updateSummary() {
            const plate  = document.getElementById('PlateNumber').value;
            const bSel   = document.getElementById('BrandId');
            const mSel   = document.getElementById('ModelId');
            const year   = document.getElementById('Year').value;
            const fuel   = document.querySelector('input[name="FuelType"]:checked')?.value || '';
            const trans  = document.getElementById('Transmission').value;
            const price  = document.getElementById('DailyPrice').value;

            let hasAny = false;

            function setRow(rowId, valId, show, text) {
                const row = document.getElementById(rowId);
                const val = document.getElementById(valId);
                row.style.display = show ? 'block' : 'none';
                if (show) { val.textContent = text; hasAny = true; }
            }

            setRow('sumPlate', 'sumPlateVal', !!plate, plate);
            const bText = bSel.options[bSel.selectedIndex]?.text;
            const mText = mSel.options[mSel.selectedIndex]?.text;
            setRow('sumBrand', 'sumBrandVal', !!(bSel.value && mSel.value), `${bText} ${mText}`);
            setRow('sumYear',  'sumYearVal',  !!year,  year);
            setRow('sumFuel',  'sumFuelVal',  !!(fuel || trans), [fuel, trans].filter(Boolean).join(' / '));
            setRow('sumPrice', 'sumPriceVal', !!price, `₺${parseFloat(price).toLocaleString('tr-TR')} / gün`);

            document.getElementById('sumEmpty').style.display = hasAny ? 'none' : 'block';
        }

        // ── Tek alan doğrulama ──
        function liveValidate(el) {
            if (!el.value || el.value === '') {
                el.classList.add('is-invalid'); el.classList.remove('is-valid');
            } else {
                el.classList.remove('is-invalid'); el.classList.add('is-valid');
            }
            updateSummary();
        }

        // ── Görsel Tab Değiştir ──
        function switchImgTab(tab) {
            const isUpload = tab === 'upload';
            document.getElementById('uploadPanel').style.display = isUpload ? 'block' : 'none';
            document.getElementById('urlPanel').style.display    = isUpload ? 'none'  : 'block';
            document.getElementById('tabUpload').classList.toggle('active', isUpload);
            document.getElementById('tabUrl').classList.toggle('active', !isUpload);
        }

        // ── Dosya yükleme ──
        function handleFileSelect(e) {
            const file = e.target.files[0];
            if (!file) return;
            if (file.size > 5 * 1024 * 1024) {
                showToast('Dosya boyutu 5 MB\'dan büyük olamaz.', 'danger'); return;
            }
            const reader = new FileReader();
            reader.onload = ev => renderImgPreview(ev.target.result, file.name);
            reader.readAsDataURL(file);
        }

        function handleDragOver(e)  { e.preventDefault(); e.currentTarget.classList.add('dragover'); }
        function handleDragLeave(e) { e.currentTarget.classList.remove('dragover'); }
        function handleDrop(e) {
            e.preventDefault(); e.currentTarget.classList.remove('dragover');
            const file = e.dataTransfer.files[0];
            if (file && file.type.startsWith('image/')) {
                const reader = new FileReader();
                reader.onload = ev => renderImgPreview(ev.target.result, file.name);
                reader.readAsDataURL(file);
            }
        }

        function renderImgPreview(src, name) {
            document.getElementById('imgPreview').src = src;
            document.getElementById('imgPreviewWrap').style.display = 'block';
            document.getElementById('imgFileName').textContent = name || '';
            document.querySelector('#uploadZone .upload-icon').style.display   = 'none';
            document.querySelector('#uploadZone .upload-title').style.display  = 'none';
            document.querySelector('#uploadZone .upload-sub').style.display    = 'none';
        }

        function clearImage() {
            document.getElementById('imageFile').value = '';
            document.getElementById('imgPreviewWrap').style.display = 'none';
            document.querySelector('#uploadZone .upload-icon').style.display  = 'flex';
            document.querySelector('#uploadZone .upload-title').style.display = 'block';
            document.querySelector('#uploadZone .upload-sub').style.display   = 'block';
        }

        function previewUrlImg(url) {
            if (!url) return;
            document.getElementById('urlPreviewWrap').style.display = 'block';
            document.getElementById('urlImgPreview').src = url;
        }

        // ── Form Doğrulama & Gönder ──
        function validateCarForm(e) {
            e.preventDefault();

            const required = ['PlateNumber','VIN','BrandId','ModelId','CategoryId',
                              'BranchId','Year','Kilometer','DailyPrice','DepositAmount','Transmission'];
            let valid = true;

            required.forEach(id => {
                const el = document.getElementById(id);
                if (!el) return;
                if (!el.value || el.value === '') {
                    el.classList.add('is-invalid'); valid = false;
                } else {
                    el.classList.remove('is-invalid'); el.classList.add('is-valid');
                }
            });

            // VIN uzunluk kontrolü
            const vin = document.getElementById('VIN');
            if (vin.value.length > 0 && vin.value.length !== 17) {
                vin.classList.add('is-invalid'); valid = false;
                document.getElementById('vinError').style.display = 'flex';
            }

            // Yakıt tipi kontrolü
            const fuel = document.querySelector('input[name="FuelType"]:checked');
            const fuelErr = document.getElementById('fuelError');
            if (!fuel) {
                fuelErr.style.cssText = 'display:flex!important;';
                valid = false;
            } else {
                fuelErr.style.cssText = 'display:none!important;';
            }

            if (!valid) {
                showToast('Lütfen zorunlu alanları eksiksiz doldurun.', 'danger');
                document.querySelector('.is-invalid')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
                return;
            }

            // Submit
            const btn = document.getElementById('submitBtn');
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Kaydediliyor…';
            btn.disabled = true;
            document.getElementById('carForm').submit();
        }

        function saveDraftCar() {
            showToast('Taslak başarıyla kaydedildi.', 'info');
        }

        // ── Yakıt seçiminde özet güncelle ──
        document.querySelectorAll('input[name="FuelType"]').forEach(r => {
            r.addEventListener('change', () => {
                document.getElementById('fuelError').style.cssText = 'display:none!important;';
                updateSummary();
            });
        });

        // ── Seçimler değiştiğinde özet güncelle ──
        ['BrandId','ModelId','CategoryId','BranchId','Year','Transmission'].forEach(id => {
            document.getElementById(id)?.addEventListener('change', updateSummary);
        })
    </script>
}


