@{
    Layout = "~/Views/AdminLayout/Index.cshtml";
}
@{
    ViewData["Title"] = "CreateCar";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

@section Styles {
    <style>
        /* ── CreateCar Page Styles ── */
        .form-section {
            background: #fff;
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow-sm);
            margin-bottom: 20px;
            overflow: hidden;
            transition: var(--transition);
        }

            .form-section:hover {
                box-shadow: var(--shadow-md);
            }

        .section-header {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 18px 24px;
            border-bottom: 1px solid var(--border);
            background: #fafbfc;
        }

        .section-icon {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            flex-shrink: 0;
        }

        .section-title {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 14.5px;
            font-weight: 700;
            color: var(--text-main);
            margin: 0;
        }

        .section-subtitle {
            font-size: 12px;
            color: var(--text-muted);
            margin: 0;
            margin-top: 1px;
        }

        .section-body {
            padding: 24px;
        }

        /* Form controls */
        .form-label {
            font-size: 13px;
            font-weight: 600;
            color: var(--text-main);
            margin-bottom: 7px;
            display: flex;
            align-items: center;
            gap: 5px;
        }

            .form-label .required {
                color: var(--danger);
                font-size: 14px;
                line-height: 1;
            }

        .form-control, .form-select {
            font-family: 'DM Sans', sans-serif;
            font-size: 13.5px;
            color: var(--text-main);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 10px 14px;
            background: #fff;
            transition: var(--transition);
            outline: none;
        }

            .form-control:focus, .form-select:focus {
                border-color: var(--primary);
                box-shadow: 0 0 0 3px rgba(26,86,219,0.1);
            }

            .form-control.is-invalid, .form-select.is-invalid {
                border-color: var(--danger);
                box-shadow: 0 0 0 3px rgba(239,68,68,0.08);
            }

            .form-control.is-valid, .form-select.is-valid {
                border-color: var(--success);
                box-shadow: 0 0 0 3px rgba(16,185,129,0.08);
            }

        .invalid-feedback {
            font-size: 12px;
            color: var(--danger);
            margin-top: 5px;
            display: none;
            align-items: center;
            gap: 4px;
        }

            .form-control.is-invalid ~ .invalid-feedback,
            .form-select.is-invalid ~ .invalid-feedback,
            .invalid-feedback.show {
                display: flex;
            }

        .form-hint {
            font-size: 12px;
            color: var(--text-muted);
            margin-top: 5px;
        }

        /* Icon inputs */
        .input-icon-wrap {
            position: relative;
        }

            .input-icon-wrap .input-icon {
                position: absolute;
                left: 13px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--text-muted);
                font-size: 14px;
                pointer-events: none;
                transition: var(--transition);
            }

            .input-icon-wrap .form-control {
                padding-left: 38px;
            }

            .input-icon-wrap:focus-within .input-icon {
                color: var(--primary);
            }

        .input-suffix {
            position: absolute;
            right: 0;
            top: 0;
            bottom: 0;
            display: flex;
            align-items: center;
            padding: 0 14px;
            font-size: 13px;
            font-weight: 600;
            color: var(--text-muted);
            border-left: 1px solid var(--border);
            background: #f8fafc;
            border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
            pointer-events: none;
        }

        /* Fuel type pill selectors */
        .fuel-options {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .fuel-radio {
            display: none;
        }

            .fuel-radio + label {
                display: flex;
                align-items: center;
                gap: 7px;
                padding: 8px 16px;
                border: 1.5px solid var(--border);
                border-radius: 40px;
                font-size: 13px;
                font-weight: 600;
                color: var(--text-muted);
                cursor: pointer;
                transition: var(--transition);
                user-select: none;
            }

                .fuel-radio + label:hover {
                    border-color: var(--primary);
                    color: var(--primary);
                    background: var(--primary-light);
                }

            .fuel-radio:checked + label {
                border-color: var(--primary);
                background: var(--primary);
                color: #fff;
                box-shadow: 0 3px 8px rgba(26,86,219,0.3);
            }

        /* Counter buttons */
        .counter-input {
            display: flex;
            align-items: center;
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            overflow: hidden;
            width: fit-content;
        }

        .counter-btn {
            width: 38px;
            height: 42px;
            border: none;
            background: #f8fafc;
            color: var(--text-muted);
            font-size: 16px;
            cursor: pointer;
            transition: var(--transition);
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .counter-btn:hover {
                background: var(--primary-light);
                color: var(--primary);
            }

        .counter-val {
            width: 52px;
            height: 42px;
            border: none;
            border-left: 1px solid var(--border);
            border-right: 1px solid var(--border);
            text-align: center;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 15px;
            font-weight: 700;
            color: var(--text-main);
            outline: none;
            background: #fff;
        }

        /* Toggle switch rows */
        .toggle-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 0;
            border-bottom: 1px solid var(--border);
        }

            .toggle-row:last-child {
                border-bottom: none;
                padding-bottom: 0;
            }

            .toggle-row:first-child {
                padding-top: 0;
            }

        .toggle-label strong {
            font-size: 13.5px;
            font-weight: 600;
            color: var(--text-main);
            display: block;
        }

        .toggle-label span {
            font-size: 12px;
            color: var(--text-muted);
        }

        .form-switch .form-check-input {
            width: 44px;
            height: 24px;
            cursor: pointer;
            border-color: var(--border);
            background-color: #e2e8f0;
        }

            .form-switch .form-check-input:checked {
                background-color: var(--primary);
                border-color: var(--primary);
            }

            .form-switch .form-check-input:focus {
                box-shadow: 0 0 0 3px rgba(26,86,219,0.15);
            }

        /* Image upload */
        .upload-zone {
            border: 2px dashed var(--border);
            border-radius: var(--radius);
            padding: 32px 20px;
            text-align: center;
            cursor: pointer;
            transition: var(--transition);
            background: #fafbfc;
            position: relative;
        }

            .upload-zone:hover, .upload-zone.dragover {
                border-color: var(--primary);
                background: var(--primary-light);
            }

            .upload-zone input[type="file"] {
                position: absolute;
                inset: 0;
                opacity: 0;
                cursor: pointer;
            }

        .upload-icon {
            width: 52px;
            height: 52px;
            background: var(--primary-light);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 12px;
            font-size: 20px;
            color: var(--primary);
            transition: var(--transition);
        }

        .upload-zone:hover .upload-icon {
            background: var(--primary);
            color: #fff;
        }

        .upload-title {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 14px;
            font-weight: 700;
            color: var(--text-main);
            margin-bottom: 4px;
        }

        .upload-sub {
            font-size: 12.5px;
            color: var(--text-muted);
        }

        #imgPreviewWrap {
            display: none;
            margin-top: 14px;
        }

        #imgPreview {
            width: 100%;
            max-height: 200px;
            object-fit: cover;
            border-radius: var(--radius-sm);
            border: 1px solid var(--border);
        }

        /* Price summary banner */
        .price-banner {
            background: linear-gradient(135deg, #1a56db, #3b82f6);
            border-radius: var(--radius);
            padding: 16px 20px;
            color: #fff;
            display: none;
        }

        /* Plate preview */
        .plate-preview {
            display: inline-flex;
            align-items: center;
            border: 2px solid #1a1a2e;
            border-radius: 6px;
            overflow: hidden;
            margin-top: 10px;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        .plate-flag {
            background: #003399;
            color: #FFD700;
            font-size: 9px;
            font-weight: 800;
            padding: 4px 6px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 1px;
        }

            .plate-flag span {
                font-size: 15px;
                line-height: 1;
            }

        .plate-number {
            background: #f8fafc;
            color: #1a1a2e;
            font-size: 18px;
            font-weight: 900;
            padding: 4px 12px;
            letter-spacing: 3px;
            min-width: 110px;
            text-align: center;
        }

        /* Steps bar */
        .form-steps {
            display: flex;
            align-items: center;
            background: #fff;
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 14px 20px;
            margin-bottom: 20px;
            overflow-x: auto;
            box-shadow: var(--shadow-sm);
            gap: 0;
        }

        .step-item {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-shrink: 0;
        }

        .step-num {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            font-weight: 700;
            flex-shrink: 0;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        .step-item.active .step-num {
            background: var(--primary);
            color: #fff;
            box-shadow: 0 0 0 4px rgba(26,86,219,0.15);
        }

        .step-label {
            font-size: 12.5px;
            font-weight: 700;
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: var(--primary);
        }

        .step-sub {
            font-size: 11px;
            color: var(--text-muted);
        }

        .step-sep {
            flex: 1;
            height: 1px;
            background: var(--border);
            margin: 0 10px;
            min-width: 16px;
        }

        /* Live summary rows */
        .sum-row {
            display: none;
            font-size: 13px;
            padding: 8px 0;
            border-bottom: 1px solid var(--border);
        }

            .sum-row:last-of-type {
                border-bottom: none;
            }

        /* Sticky action bar */
        .action-bar {
            position: sticky;
            bottom: 0;
            background: #fff;
            border-top: 1px solid var(--border);
            padding: 14px 0;
            margin-top: 4px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 10px;
            z-index: 100;
            box-shadow: 0 -4px 20px rgba(0,0,0,0.07);
        }

        .btn-cancel-form {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            background: #fff;
            border: 1px solid var(--border);
            color: var(--text-muted);
            border-radius: var(--radius-sm);
            padding: 10px 20px;
            font-size: 13.5px;
            font-weight: 600;
            font-family: 'DM Sans', sans-serif;
            cursor: pointer;
            transition: var(--transition);
            text-decoration: none;
        }

            .btn-cancel-form:hover {
                background: #f8fafc;
                color: var(--text-main);
                border-color: #94a3b8;
            }

        .btn-draft {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            background: #f8fafc;
            border: 1px solid var(--border);
            color: var(--text-main);
            border-radius: var(--radius-sm);
            padding: 10px 20px;
            font-size: 13.5px;
            font-weight: 600;
            font-family: 'DM Sans', sans-serif;
            cursor: pointer;
            transition: var(--transition);
        }

            .btn-draft:hover {
                background: #f1f5f9;
                border-color: #94a3b8;
            }

        .btn-submit-car {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: var(--primary);
            color: #fff;
            border: none;
            border-radius: var(--radius-sm);
            padding: 10px 24px;
            font-size: 13.5px;
            font-weight: 700;
            font-family: 'DM Sans', sans-serif;
            cursor: pointer;
            transition: var(--transition);
        }

            .btn-submit-car:hover {
                background: var(--primary-dark);
                box-shadow: 0 4px 14px rgba(26,86,219,0.4);
                transform: translateY(-1px);
            }

            .btn-submit-car:disabled {
                opacity: .7;
                cursor: not-allowed;
                transform: none;
            }

        /* char counter */
        .char-count {
            font-size: 11.5px;
            color: var(--text-muted);
            text-align: right;
            margin-top: 4px;
        }

        /* img tab switch */
        .img-tabs {
            display: flex;
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            overflow: hidden;
            margin-bottom: 14px;
        }

        .img-tab-btn {
            flex: 1;
            padding: 8px;
            font-size: 13px;
            font-weight: 600;
            font-family: 'DM Sans', sans-serif;
            border: none;
            cursor: pointer;
            transition: var(--transition);
        }

            .img-tab-btn.active {
                background: var(--primary);
                color: #fff;
            }

            .img-tab-btn:not(.active) {
                background: #f8fafc;
                color: var(--text-muted);
            }

        @@media (max-width: 767px) {
            .section-body {
                padding: 14px;
            }

            .action-bar {
                padding: 12px 0;
            }

            .step-sub {
                display: none;
            }

            .step-sep {
                min-width: 8px;
                margin: 0 6px;
            }
        }
    </style>
}

<!-- Page Header -->
<div class="page-header">
    <div>
        <h1 class="page-title">Yeni Araç Ekle</h1>
        <p class="page-subtitle">Filoya yeni bir araç kaydı oluşturun.</p>
    </div>
    <a href="/Car/Index" class="btn-cancel-form">
        <i class="fa-solid fa-arrow-left"></i> Listeye Dön
    </a>
</div>

<!-- Steps indicator -->
<div class="form-steps">
    <div class="step-item active">
        <div class="step-num"><i class="fa-solid fa-car"></i></div>
        <div>
            <div class="step-label">Kimlik & Sınıf</div>
            <div class="step-sub">Plaka, VIN, marka</div>
        </div>
    </div>
    <div class="step-sep"></div>
    <div class="step-item active">
        <div class="step-num"><i class="fa-solid fa-gauge"></i></div>
        <div>
            <div class="step-label">Teknik</div>
            <div class="step-sub">Yıl, yakıt, koltuk</div>
        </div>
    </div>
    <div class="step-sep"></div>
    <div class="step-item active">
        <div class="step-num"><i class="fa-solid fa-lira-sign"></i></div>
        <div>
            <div class="step-label">Fiyatlandırma</div>
            <div class="step-sub">Günlük & depozito</div>
        </div>
    </div>
    <div class="step-sep"></div>
    <div class="step-item active">
        <div class="step-num"><i class="fa-solid fa-image"></i></div>
        <div>
            <div class="step-label">Medya & Durum</div>
            <div class="step-sub">Görsel & aktiflik</div>
        </div>
    </div>
</div>

<form id="carForm" asp-action="Create" asp-controller="Car" method="post" enctype="multipart/form-data" novalidate>
    @Html.AntiForgeryToken()

    <div class="row g-4">

        <!-- ═══ LEFT COLUMN ═══ -->
        <div class="col-12 col-xl-8">

            <!-- 1 · Kimlik Bilgileri -->
            <div class="form-section">
                <div class="section-header">
                    <div class="section-icon" style="background:#e8efff;color:var(--primary);">
                        <i class="fa-solid fa-id-card"></i>
                    </div>
                    <div>
                        <p class="section-title">Araç Kimlik Bilgileri</p>
                        <p class="section-subtitle">Plaka ve şasi numarası zorunludur</p>
                    </div>
                </div>
                <div class="section-body">
                    <div class="row g-3">

                        <!-- Plaka -->
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="PlateNumber">
                                Plaka Numarası <span class="required">*</span>
                            </label>
                            <div class="input-icon-wrap">
                                <input type="text"
                                       id="PlateNumber"
                                       name="PlateNumber"
                                       class="form-control"
                                       placeholder="34 ABC 123"
                                       maxlength="10"
                                       autocomplete="off"
                                       style="font-weight:700;letter-spacing:2px;font-family:'Plus Jakarta Sans',sans-serif;"
                                       oninput="this.value=this.value.toUpperCase(); updatePlatePreview(); liveValidate(this)" />
                                <i class="fa-solid fa-hashtag input-icon"></i>
                            </div>
                            <div class="invalid-feedback" id="plateError">
                                <i class="fa-solid fa-circle-exclamation"></i> Plaka numarası zorunludur.
                            </div>
                            <!-- Canlı plaka önizlemesi -->
                            <div id="platePreviewWrap" style="display:none; margin-top:10px;">
                                <div class="plate-preview">
                                    <div class="plate-flag">
                                        <span>🇹🇷</span>
                                        <small style="letter-spacing:1px;">TR</small>
                                    </div>
                                    <div class="plate-number" id="platePreviewText">— — —</div>
                                </div>
                            </div>
                        </div>

                        <!-- VIN / Şasi No -->
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="VIN">
                                Şasi Numarası (VIN) <span class="required">*</span>
                            </label>
                            <div class="input-icon-wrap">
                                <input type="text"
                                       id="VIN"
                                       name="VIN"
                                       class="form-control"
                                       placeholder="WBA5A5C5XED123456"
                                       maxlength="17"
                                       autocomplete="off"
                                       style="font-family:monospace;letter-spacing:1px;font-size:13px;"
                                       oninput="this.value=this.value.toUpperCase(); updateVinCount(); liveValidate(this)" />
                                <i class="fa-solid fa-barcode input-icon"></i>
                            </div>
                            <div class="d-flex justify-content-between align-items-start mt-1">
                                <div class="invalid-feedback" id="vinError">
                                    <i class="fa-solid fa-circle-exclamation"></i> 17 haneli VIN numarası giriniz.
                                </div>
                                <div class="char-count ms-auto"><span id="vinCount">0</span>/17</div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            <!-- 2 · Sınıflandırma -->
            <div class="form-section">
                <div class="section-header">
                    <div class="section-icon" style="background:#fff4ed;color:var(--accent);">
                        <i class="fa-solid fa-layer-group"></i>
                    </div>
                    <div>
                        <p class="section-title">Sınıflandırma</p>
                        <p class="section-subtitle">Marka, model, kategori ve şube</p>
                    </div>
                </div>
                <div class="section-body">
                    <div class="row g-3">

                        <div class="col-12 col-sm-6">
                            <label class="form-label" for="BrandId">
                                Marka <span class="required">*</span>
                            </label>
                            <select id="BrandId" name="BrandId" class="form-select"
                                    onchange="loadModels(this.value); liveValidate(this); updateSummary()">
                                <option value="">— Marka Seçin —</option>
                                @* ViewBag.Brands listesi buraya bind edilecek *@
                                @if (ViewBag.Brands != null)
                                {
                                    foreach (var brand in ViewBag.Brands)
                                    {
                                        <option value="@brand.BrandId">@brand.BrandName</option>
                                    }
                                }
                                else
                                {
                                    <!-- Statik fallback (geliştirme ortamı) -->
                                    <option value="1">BMW</option>
                                    <option value="2">Mercedes-Benz</option>
                                    <option value="3">Audi</option>
                                    <option value="4">Toyota</option>
                                    <option value="5">Volkswagen</option>
                                    <option value="6">Ford</option>
                                    <option value="7">Volvo</option>
                                    <option value="8">Hyundai</option>
                                    <option value="9">Tesla</option>
                                    <option value="10">Renault</option>
                                }
                            </select>
                            <div class="invalid-feedback" id="brandError">
                                <i class="fa-solid fa-circle-exclamation"></i> Marka seçimi zorunludur.
                            </div>
                        </div>

                        <div class="col-12 col-sm-6">
                            <label class="form-label" for="ModelId">
                                Model <span class="required">*</span>
                            </label>
                            <select id="ModelId" name="ModelId" class="form-select"
                                    onchange="liveValidate(this); updateSummary()">
                                <option value="">— Önce marka seçin —</option>
                                @if (ViewBag.Models != null)
                                {
                                    foreach (var model in ViewBag.Models)
                                    {
                                        <option value="@@model.ModelId">@@model.ModelName</option>
                                    }
                                }
                            </select>
                            <div class="invalid-feedback" id="modelError">
                                <i class="fa-solid fa-circle-exclamation"></i> Model seçimi zorunludur.
                            </div>
                        </div>

                        <div class="col-12 col-sm-6">
                            <label class="form-label" for="CategoryId">
                                Kategori <span class="required">*</span>
                            </label>
                            <select id="CategoryId" name="CategoryId" class="form-select"
                                    onchange="liveValidate(this)">
                                <option value="">— Kategori Seçin —</option>
                                @if (ViewBag.Categories != null)
                                {
                                    foreach (var cat in ViewBag.Categories)
                                    {
                                        <option value="@cat.CategoryId">@cat.CategoryName</option>
                                    }
                                }
                                else
                                {
                                    <option value="1">Sedan</option>
                                    <option value="2">SUV / Crossover</option>
                                    <option value="3">Hatchback</option>
                                    <option value="4">Station Wagon</option>
                                    <option value="5">Coupe</option>
                                    <option value="6">Minivan / MPV</option>
                                    <option value="7">Pick-up</option>
                                    <option value="8">Cabrio</option>
                                    <option value="9">Elektrikli</option>
                                }
                            </select>
                            <div class="invalid-feedback" id="categoryError">
                                <i class="fa-solid fa-circle-exclamation"></i> Kategori seçimi zorunludur.
                            </div>
                        </div>

                        <div class="col-12 col-sm-6">
                            <label class="form-label" for="BranchId">
                                Şube <span class="required">*</span>
                            </label>
                            <select id="BranchId" name="BranchId" class="form-select"
                                    onchange="liveValidate(this)">
                                <option value="">— Şube Seçin —</option>
                                @if (ViewBag.Branches != null)
                                {
                                    foreach (var branch in ViewBag.Branches)
                                    {
                                        <option value="@branch.BranchId">@branch.BranchName</option>
                                    }
                                }
                                else
                                {
                                    <option value="1">İstanbul — Merkez</option>
                                    <option value="2">İstanbul — Atatürk Hav.</option>
                                    <option value="3">İstanbul — Sabiha Gökcen</option>
                                    <option value="4">Ankara — Merkez</option>
                                    <option value="5">İzmir — Merkez</option>
                                    <option value="6">Antalya — Hava Limanı</option>
                                    <option value="7">Bursa — Merkez</option>
                                }
                            </select>
                            <div class="invalid-feedback" id="branchError">
                                <i class="fa-solid fa-circle-exclamation"></i> Şube seçimi zorunludur.
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            <!-- 3 · Teknik Detaylar -->
            <div class="form-section">
                <div class="section-header">
                    <div class="section-icon" style="background:#f0fdf4;color:#10b981;">
                        <i class="fa-solid fa-screwdriver-wrench"></i>
                    </div>
                    <div>
                        <p class="section-title">Teknik Detaylar</p>
                        <p class="section-subtitle">Yıl, kilometre, yakıt tipi ve koltuk bilgileri</p>
                    </div>
                </div>
                <div class="section-body">
                    <div class="row g-3">

                        <div class="col-12 col-sm-6 col-md-4">
                            <label class="form-label" for="Year">
                                Model Yılı <span class="required">*</span>
                            </label>
                            <div class="input-icon-wrap">
                                <input type="number" id="Year" name="Year"
                                       class="form-control"
                                       placeholder="2024" min="1990" max="2026"
                                       oninput="liveValidate(this); updateSummary()" />
                                <i class="fa-solid fa-calendar input-icon"></i>
                            </div>
                            <div class="invalid-feedback" id="yearError">
                                <i class="fa-solid fa-circle-exclamation"></i> Geçerli bir yıl giriniz.
                            </div>
                        </div>

                        <div class="col-12 col-sm-6 col-md-4">
                            <label class="form-label" for="Kilometer">
                                Kilometre <span class="required">*</span>
                            </label>
                            <div class="input-icon-wrap" style="position:relative;">
                                <input type="number" id="Kilometer" name="Kilometer"
                                       class="form-control"
                                       placeholder="0" min="0"
                                       style="padding-right:50px;"
                                       oninput="liveValidate(this)" />
                                <i class="fa-solid fa-road input-icon"></i>
                                <span class="input-suffix">km</span>
                            </div>
                            <div class="invalid-feedback" id="kmError">
                                <i class="fa-solid fa-circle-exclamation"></i> Kilometre bilgisi zorunludur.
                            </div>
                        </div>

                        <div class="col-12 col-sm-6 col-md-4">
                            <label class="form-label" for="Transmission">
                                Vites Tipi <span class="required">*</span>
                            </label>
                            <select id="Transmission" name="Transmission" class="form-select"
                                    onchange="liveValidate(this); updateSummary()">
                                <option value="">— Seçin —</option>
