@{
    Layout = "~/Views/AdminLayout/Index.cshtml";
}


<div class="page-header">
    <div>
        <h1 class="page-title">Araç Listesi</h1>
        <p class="page-subtitle">Filodaki tüm araçları görüntüleyin ve yönetin.</p>
    </div>
    <button class="btn-primary-custom" onclick="showToast('Yeni araç ekleme formu açıldı!', 'info')">
        <i class="fa-solid fa-plus"></i> Yeni Araç Ekle
    </button>
</div>


<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="stat-card text-center py-3">
            <div style="font-family:'Plus Jakarta Sans',sans-serif;font-size:28px;font-weight:800;color:var(--text-main);" id="totalCount">10</div>
            <div style="font-size:12.5px;color:var(--text-muted);">Toplam Araç</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card text-center py-3">
            <div style="font-family:'Plus Jakarta Sans',sans-serif;font-size:28px;font-weight:800;color:#10b981;" id="availableCount">7</div>
            <div style="font-size:12.5px;color:var(--text-muted);">Müsait</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card text-center py-3">
            <div style="font-family:'Plus Jakarta Sans',sans-serif;font-size:28px;font-weight:800;color:var(--accent);" id="rentedCount">3</div>
            <div style="font-size:12.5px;color:var(--text-muted);">Kirada</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card text-center py-3">
            <div style="font-family:'Plus Jakarta Sans',sans-serif;font-size:28px;font-weight:800;color:var(--primary);" id="visibleCount">10</div>
            <div style="font-size:12.5px;color:var(--text-muted);">Gösterilen</div>
        </div>
    </div>
</div>


<div class="toolbar-card">
    <div class="search-wrap">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" id="searchInput" placeholder="Araç ara (marka, model, yıl...)" oninput="filterVehicles()" />
    </div>
    <select class="filter-select" id="brandFilter" onchange="filterVehicles()">
        <option value="">Tüm Markalar</option>
        <option value="BMW">BMW</option>
        <option value="Mercedes">Mercedes</option>
        <option value="Toyota">Toyota</option>
        <option value="Audi">Audi</option>
        <option value="Volkswagen">Volkswagen</option>
        <option value="Ford">Ford</option>
        <option value="Volvo">Volvo</option>
        <option value="Hyundai">Hyundai</option>
        <option value="Tesla">Tesla</option>
    </select>
    <select class="filter-select" id="statusFilter" onchange="filterVehicles()">
        <option value="">Tüm Durumlar</option>
        <option value="Müsait">Müsait</option>
        <option value="Kirada">Kirada</option>
    </select>
    <select class="filter-select" id="fuelFilter" onchange="filterVehicles()">
        <option value="">Tüm Yakıt Tipleri</option>
        <option value="Benzin">Benzin</option>
        <option value="Dizel">Dizel</option>
        <option value="Elektrik">Elektrik</option>
        <option value="Hibrit">Hibrit</option>
    </select>
    <button class="btn-action btn-detail" onclick="resetFilters()" style="flex:none;padding:9px 14px;font-size:13px;">
        <i class="fa-solid fa-rotate-left"></i> Sıfırla
    </button>
</div>

<p class="results-count" id="resultsText">
    Toplam <strong>10</strong> araç listeleniyor
</p>


<div class="row g-4" id="vehicleGrid">

</div>


<div id="emptyState" class="text-center py-5" style="display:none!important;">
    <div style="font-size:56px;color:var(--border);margin-bottom:16px;"><i class="fa-solid fa-car-burst"></i></div>
    <h5 style="font-family:'Plus Jakarta Sans',sans-serif;font-weight:700;">Araç Bulunamadı</h5>
    <p style="color:var(--text-muted);font-size:14px;">Arama veya filtre kriterlerinizi değiştirmeyi deneyin.</p>
    <button class="btn-primary-custom" onclick="resetFilters()"><i class="fa-solid fa-rotate-left"></i> Filtreleri Temizle</button>
</div>

