@model List<Rentaly.EntityLayer.Entities.Category>
@{
    Layout = "~/Views/AdminLayout/Index.cshtml";
}


<style>
    /* ── Category List Page ── */
    .cat-toolbar {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 14px 18px;
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        box-shadow: var(--shadow-sm);
        margin-bottom: 20px;
    }

    .cat-search-wrap {
        position: relative;
        flex: 1;
        min-width: 200px;
    }

        .cat-search-wrap i {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            font-size: 14px;
            pointer-events: none;
        }

        .cat-search-wrap input {
            width: 100%;
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 9px 12px 9px 36px;
            font-size: 13.5px;
            font-family: 'DM Sans', sans-serif;
            color: var(--text-main);
            background: var(--body-bg);
            outline: none;
            transition: var(--transition);
        }

            .cat-search-wrap input:focus {
                border-color: var(--primary);
                background: #fff;
                box-shadow: 0 0 0 3px rgba(26,86,219,0.1);
            }

    /* Table card */
    .table-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow-sm);
        overflow: hidden;
    }

        .table-card table {
            width: 100%;
            border-collapse: collapse;
            margin: 0;
        }

        .table-card thead tr {
            background: #f8fafc;
            border-bottom: 1px solid var(--border);
        }

        .table-card thead th {
            padding: 12px 18px;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 11.5px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.7px;
            color: var(--text-muted);
            white-space: nowrap;
            cursor: pointer;
            user-select: none;
            transition: var(--transition);
        }

            .table-card thead th:hover {
                color: var(--primary);
            }

            .table-card thead th .sort-icon {
                margin-left: 4px;
                opacity: .4;
                font-size: 10px;
            }

            .table-card thead th.sorted .sort-icon {
                opacity: 1;
                color: var(--primary);
            }

        .table-card tbody tr {
            border-bottom: 1px solid var(--border);
            transition: var(--transition);
        }

            .table-card tbody tr:last-child {
                border-bottom: none;
            }

            .table-card tbody tr:hover {
                background: #f8faff;
            }

        .table-card tbody td {
            padding: 13px 18px;
            font-size: 13.5px;
            color: var(--text-main);
            vertical-align: middle;
        }

    /* ID badge */
    .id-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        background: var(--primary-light);
        color: var(--primary);
        border-radius: 8px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 12px;
        font-weight: 800;
    }

    /* Category name with icon */
    .cat-name-cell {
        display: flex;
        align-items: center;
        gap: 11px;
    }

    .cat-icon-box {
        width: 36px;
        height: 36px;
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 15px;
        flex-shrink: 0;
    }

    /* Action buttons */
    .tbl-btn {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 6px 12px;
        border-radius: var(--radius-sm);
        font-size: 12.5px;
        font-weight: 600;
        font-family: 'DM Sans', sans-serif;
        cursor: pointer;
        transition: var(--transition);
        border: none;
        text-decoration: none;
    }

    .tbl-btn-edit {
        background: #fef3c7;
        color: #92400e;
    }

        .tbl-btn-edit:hover {
            background: var(--warning);
            color: #fff;
        }

    .tbl-btn-delete {
        background: #fee2e2;
        color: var(--danger);
    }

        .tbl-btn-delete:hover {
            background: var(--danger);
            color: #fff;
        }

    /* Empty state */
    .empty-state {
        padding: 52px 20px;
        text-align: center;
    }

    .empty-icon {
        width: 64px;
        height: 64px;
        background: var(--primary-light);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 26px;
        color: var(--primary);
        margin: 0 auto 16px;
    }

    /* Pagination */
    .paging-wrap {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 12px 18px;
        border-top: 1px solid var(--border);
        background: #fafbfc;
        flex-wrap: wrap;
        gap: 8px;
    }

    .paging-info {
        font-size: 13px;
        color: var(--text-muted);
    }

    .paging-btns {
        display: flex;
        gap: 4px;
    }

    .page-btn {
        width: 32px;
        height: 32px;
        border: 1px solid var(--border);
        background: #fff;
        border-radius: var(--radius-sm);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: var(--transition);
        color: var(--text-main);
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

        .page-btn:hover {
            background: var(--primary-light);
            border-color: var(--primary);
            color: var(--primary);
        }

        .page-btn.active {
            background: var(--primary);
            border-color: var(--primary);
            color: #fff;
        }

        .page-btn:disabled {
            opacity: .4;
            cursor: not-allowed;
        }

    /* Add / Edit Modal */
    .modal-content {
        border: none;
        border-radius: var(--radius);
        box-shadow: var(--shadow-lg);
    }

    .modal-header {
        border-bottom: 1px solid var(--border);
        padding: 18px 22px;
        background: #fafbfc;
        border-radius: var(--radius) var(--radius) 0 0;
    }

    .modal-title {
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 15px;
        font-weight: 800;
    }

    .modal-body {
        padding: 22px;
    }

    .modal-footer {
        border-top: 1px solid var(--border);
        padding: 14px 22px;
        background: #fafbfc;
    }

    .modal-form-label {
        font-size: 13px;
        font-weight: 600;
        color: var(--text-main);
        margin-bottom: 7px;
        display: block;
    }

    .modal-form-control {
        width: 100%;
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        padding: 10px 14px;
        font-size: 13.5px;
        font-family: 'DM Sans', sans-serif;
        color: var(--text-main);
        outline: none;
        transition: var(--transition);
    }

        .modal-form-control:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(26,86,219,0.1);
        }

        .modal-form-control.is-invalid {
            border-color: var(--danger);
            box-shadow: 0 0 0 3px rgba(239,68,68,0.08);
        }

    /* Color picker row */
    .color-options {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-top: 6px;
    }

    .color-dot-radio {
        display: none;
    }

        .color-dot-radio + label {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            cursor: pointer;
            border: 2.5px solid transparent;
            transition: var(--transition);
            display: block;
        }

            .color-dot-radio:checked + label,
            .color-dot-radio + label:hover {
                border-color: var(--text-main);
                transform: scale(1.15);
            }

    /* Stat mini cards */
    .mini-stat {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 16px 20px;
        box-shadow: var(--shadow-sm);
        display: flex;
        align-items: center;
        gap: 14px;
        transition: var(--transition);
    }

        .mini-stat:hover {
            box-shadow: var(--shadow-md);
            transform: translateY(-2px);
        }

    .mini-stat-icon {
        width: 44px;
        height: 44px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        flex-shrink: 0;
    }

    .mini-stat-val {
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 24px;
        font-weight: 800;
        color: var(--text-main);
        line-height: 1;
    }

    .mini-stat-label {
        font-size: 12.5px;
        color: var(--text-muted);
        margin-top: 3px;
    }

    @@media (max-width: 575px) {
        .table-card thead th:nth-child(1) {
            display: none;
        }

        .table-card tbody td:nth-child(1) {
            display: none;
        }

        .tbl-btn span {
            display: none;
        }

        .tbl-btn {
            padding: 7px;
        }
    }
</style>

<!-- ═══ Page Header ═══ -->
<div class="page-header">
    <div>
        <h1 class="page-title">Kategori Listesi</h1>
        <p class="page-subtitle">Araç kategorilerini görüntüleyin ve yönetin.</p>
    </div>
    <button class="btn-primary-custom" onclick="openAddModal()">
        <i class="fa-solid fa-plus"></i> Yeni Kategori
    </button>
</div>

<!-- ═══ Mini İstatistikler ═══ -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-4">
        <div class="mini-stat">
            <div class="mini-stat-icon" style="background:#e8efff;color:var(--primary);">
                <i class="fa-solid fa-tags"></i>
            </div>
            <div>
                <div class="mini-stat-val" id="statTotal">@Model.Count()</div>
                <div class="mini-stat-label">Toplam Kategori</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4">
        <div class="mini-stat">
            <div class="mini-stat-icon" style="background:#f0fdf4;color:#10b981;">
                <i class="fa-solid fa-circle-check"></i>
            </div>
            <div>
                <div class="mini-stat-val" style="color:#10b981;" id="statFiltered">@Model.Count()</div>
                <div class="mini-stat-label">Gösterilen</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 d-none d-md-block">
        <div class="mini-stat">
            <div class="mini-stat-icon" style="background:#fff4ed;color:var(--accent);">
                <i class="fa-solid fa-clock-rotate-left"></i>
            </div>
            <div>
                <div class="mini-stat-val" style="color:var(--accent);" id="statLast">
                    @(Model.Any() ? Model.Last().CategoryName.Substring(0, Math.Min(8, Model.Last().CategoryName.Length)) + "…" : "—")
                </div>
                <div class="mini-stat-label">Son Eklenen</div>
            </div>
        </div>
    </div>
</div>

<!-- ═══ Toolbar ═══ -->
<div class="cat-toolbar">
    <div class="cat-search-wrap">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" id="catSearch" placeholder="Kategori adı ara…" oninput="filterCategories()" />
    </div>
    <select class="filter-select" id="sortSelect" onchange="sortCategories()" style="min-width:160px;">
        <option value="id-asc">ID — Artan</option>
        <option value="id-desc">ID — Azalan</option>
        <option value="name-asc">İsim — A→Z</option>
        <option value="name-desc">İsim — Z→A</option>
    </select>
    <button class="btn-action btn-detail" onclick="resetCatFilters()" style="flex:none;padding:9px 14px;font-size:13px;white-space:nowrap;">
        <i class="fa-solid fa-rotate-left"></i> Sıfırla
    </button>
</div>

<!-- ═══ Tablo ═══ -->
<div class="table-card">
    <table id="catTable">
        <thead>
            <tr>
                <th onclick="sortBy('id')" style="width:80px;">
                    # <i class="fa-solid fa-sort sort-icon" id="sort-id"></i>
                </th>
                <th onclick="sortBy('name')">
                    Kategori Adı <i class="fa-solid fa-sort sort-icon" id="sort-name"></i>
                </th>
                <th style="width:100px;text-align:center;">
                    Araç Sayısı
                </th>
                <th style="width:160px;text-align:right;">İşlemler</th>
            </tr>
        </thead>
        <tbody id="catTableBody">
            @{
                var colorPairs = new[] {
                    ("#e8efff","#1a56db"), ("#fff4ed","#f97316"), ("#f0fdf4","#10b981"),
                    ("#fefce8","#d97706"), ("#fdf4ff","#9333ea"), ("#fff1f2","#ef4444"),
                    ("#f0f9ff","#0284c7"), ("#f7fee7","#65a30d"), ("#fdf2f8","#db2777"),
                    ("#f5f3ff","#7c3aed")
                };
                int idx = 0;
            }
            @foreach (var cat in Model)
            {
                var (bg, fg) = colorPairs[idx % colorPairs.Length];
                var icons = new[] { "fa-car-side","fa-truck","fa-motorcycle","fa-van-shuttle",
                                    "fa-car-rear","fa-bus","fa-taxi","fa-jeep","fa-car","fa-rocket" };
                var icon = icons[idx % icons.Length];
                idx++;

                <tr data-id="@cat.CategoryId" data-name="@cat.CategoryName.ToLower()">
                    <td>
                        <span class="id-badge">@cat.CategoryId</span>
                    </td>
                    <td>
                        <div class="cat-name-cell">
                            <div class="cat-icon-box" style="background:@bg;color:@fg;">
                                <i class="fa-solid @icon"></i>
                            </div>
                            <div>
                                <div style="font-weight:600;font-size:14px;">@cat.CategoryName</div>
                                <div style="font-size:11.5px;color:var(--text-muted);">Kategori #@cat.CategoryId</div>
                            </div>
                        </div>
                    </td>
                    <td style="text-align:center;">
                        <span style="
                            background:var(--primary-light);
                            color:var(--primary);
                            font-family:'Plus Jakarta Sans',sans-serif;
                            font-size:13px;font-weight:700;
                            padding:3px 10px;border-radius:20px;">
                            —
                        </span>
                    </td>
                    <td>
                        <div style="display:flex;gap:6px;justify-content:flex-end;">
                            <button class="tbl-btn tbl-btn-edit"
                                    onclick="openEditModal(@cat.CategoryId, '@cat.CategoryName')">
                                <i class="fa-solid fa-pen-to-square"></i>
                                <span>Düzenle</span>
                            </button>
                            <button class="tbl-btn tbl-btn-delete"
                                    onclick="openDeleteModal(@cat.CategoryId, '@cat.CategoryName')">
                                <i class="fa-solid fa-trash-can"></i>
                                <span>Sil</span>
                            </button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <!-- Boş durum -->
    <div class="empty-state" id="emptyState" style="display:none;">
        <div class="empty-icon"><i class="fa-solid fa-tags"></i></div>
        <h6 style="font-family:'Plus Jakarta Sans',sans-serif;font-weight:700;margin-bottom:6px;">Kategori Bulunamadı</h6>
        <p style="font-size:13.5px;color:var(--text-muted);margin-bottom:14px;">
            Arama kriterinizle eşleşen kategori yok.
        </p>
        <button class="btn-primary-custom" onclick="resetCatFilters()">
            <i class="fa-solid fa-rotate-left"></i> Filtreyi Temizle
        </button>
    </div>

    <!-- Pagination -->
    <div class="paging-wrap" id="pagingWrap">
        <div class="paging-info" id="pagingInfo">—</div>
        <div class="paging-btns" id="pagingBtns"></div>
    </div>
</div>

<!-- ═══════════════════════════════
     EKLE / DÜZENLE MODAL
═══════════════════════════════ -->
<div class="modal fade" id="catModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered" style="max-width:420px;">
        <div class="modal-content">
            <div class="modal-header">
                <div style="display:flex;align-items:center;gap:10px;">
                    <div style="width:34px;height:34px;background:var(--primary-light);border-radius:8px;display:flex;align-items:center;justify-content:center;color:var(--primary);font-size:15px;">
                        <i class="fa-solid fa-tags" id="modalHeaderIcon"></i>
                    </div>
                    <h5 class="modal-title" id="modalTitle">Yeni Kategori</h5>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="catModalForm" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="modalCatId" name="CategoryId" value="0" />
                <div class="modal-body">

                    <div style="margin-bottom:18px;">
                        <label class="modal-form-label" for="modalCatName">
                            Kategori Adı <span style="color:var(--danger);">*</span>
                        </label>
                        <input type="text"
                               id="modalCatName"
                               name="CategoryName"
                               class="modal-form-control"
                               placeholder="Örn: Sedan, SUV, Elektrikli…"
                               maxlength="50"
                               oninput="updateModalCharCount(this)" />
                        <div style="display:flex;justify-content:space-between;margin-top:5px;">
                            <span class="invalid-feedback" id="modalNameError" style="display:none;font-size:12px;color:var(--danger);">
                                <i class="fa-solid fa-circle-exclamation"></i> Kategori adı zorunludur.
                            </span>
                            <span style="font-size:11.5px;color:var(--text-muted);margin-left:auto;">
                                <span id="modalCharCount">0</span>/50
                            </span>
                        </div>
                    </div>

                    <!-- İkon Rengi Seçici (görsel; opsiyonel) -->
                    <div>
                        <label class="modal-form-label">Renk Etiketi</label>
                        <div class="color-options">
                            @{
                                var dotColors = new[] {
                                    ("#1a56db","Mavi"), ("#f97316","Turuncu"), ("#10b981","Yeşil"),
                                    ("#ef4444","Kırmızı"), ("#9333ea","Mor"), ("#d97706","Sarı"),
                                    ("#0284c7","Açık Mavi"), ("#db2777","Pembe")
                                };
                            }
                            @foreach (var (color, label) in dotColors)
                            {
                                <input type="radio" class="color-dot-radio"
                                       name="ColorTag" id="color_@color.Replace("#", "")"
                                       value="@color" />
                                <label for="color_@color.Replace("#", "")"
                                       style="background:@color;"
                                       title="@label"></label>
                            }
                        </div>
                        <p style="font-size:11.5px;color:var(--text-muted);margin-top:6px;">
                            <i class="fa-solid fa-circle-info me-1" style="color:var(--primary);"></i>
                            İsteğe bağlı — kategori için renk etiketi
                        </p>
                    </div>

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-cancel-form" data-bs-dismiss="modal"
                            style="display:inline-flex;align-items:center;gap:6px;">
                        <i class="fa-solid fa-xmark"></i> İptal
                    </button>
                    <button type="button" class="btn-submit-car" id="modalSaveBtn"
                            onclick="submitCatModal()"
                            style="display:inline-flex;align-items:center;gap:7px;padding:9px 22px;">
                        <i class="fa-solid fa-check"></i>
                        <span id="modalSaveBtnText">Kaydet</span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ═══════════════════════════════
     SİL ONAY MODAL
═══════════════════════════════ -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered" style="max-width:400px;">
        <div class="modal-content">
            <div class="modal-header">
                <div style="display:flex;align-items:center;gap:10px;">
                    <div style="width:34px;height:34px;background:#fee2e2;border-radius:8px;display:flex;align-items:center;justify-content:center;color:var(--danger);font-size:15px;">
                        <i class="fa-solid fa-trash-can"></i>
                    </div>
                    <h5 class="modal-title">Kategori Sil</h5>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div style="display:flex;gap:14px;align-items:flex-start;">
                    <div style="width:46px;height:46px;background:#fee2e2;border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--danger);font-size:20px;flex-shrink:0;">
                        <i class="fa-solid fa-triangle-exclamation"></i>
                    </div>
                    <div>
                        <p style="margin:0;font-size:14.5px;color:var(--text-main);line-height:1.5;">
                            <strong id="deleteCatName">bu kategoriyi</strong> silmek istediğinizden emin misiniz?
                        </p>
                        <p style="margin:6px 0 0;font-size:13px;color:var(--text-muted);">
                            Bu işlem geri alınamaz. İlgili araçlar kategorisiz kalabilir.
                        </p>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-cancel-form" data-bs-dismiss="modal"
                        style="display:inline-flex;align-items:center;gap:6px;">
                    <i class="fa-solid fa-xmark"></i> Vazgeç
                </button>
                <form id="deleteForm" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="deleteCatId" name="id" />
                    <button type="submit"
                            style="display:inline-flex;align-items:center;gap:7px;background:var(--danger);color:#fff;border:none;border-radius:var(--radius-sm);padding:9px 22px;font-size:13.5px;font-weight:700;font-family:'DM Sans',sans-serif;cursor:pointer;transition:var(--transition);">
                        <i class="fa-solid fa-trash-can"></i> Evet, Sil
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="toast-container position-fixed bottom-0 end-0 p-3" id="toastContainer"></div>

<script>
    /* ══════════════════════════════════════════
       Category List Page Scripts
    ══════════════════════════════════════════ */

    // ── Tüm satırları al ──
    const allRows = () => [...document.querySelectorAll('#catTableBody tr[data-id]')];

    // ── Arama ──
    function filterCategories() {
        const q = document.getElementById('catSearch').value.toLowerCase().trim();
        let visible = 0;
        allRows().forEach(row => {
            const name = row.dataset.name || '';
            const id   = row.dataset.id   || '';
            const show = !q || name.includes(q) || id.includes(q);
            row.style.display = show ? '' : 'none';
            if (show) visible++;
        });
        document.getElementById('statFiltered').textContent = visible;
        document.getElementById('emptyState').style.display = visible === 0 ? 'block' : 'none';
        buildPaging();
    }

    // ── Sıralama (select) ──
    function sortCategories() {
        const val = document.getElementById('sortSelect').value;
        const [field, dir] = val.split('-');
        sortBy(field, dir);
    }

    // ── Sıralama (kolon başlığı tıklama) ──
    let lastSort = { field: 'id', dir: 'asc' };
    function sortBy(field, dir) {
        if (!dir) {
            dir = (lastSort.field === field && lastSort.dir === 'asc') ? 'desc' : 'asc';
        }
        lastSort = { field, dir };

        // İkon güncelle
        ['id','name'].forEach(f => {
            const el = document.getElementById('sort-' + f);
            if (!el) return;
            el.className = f === field
                ? ('fa-solid fa-sort-' + (dir === 'asc' ? 'up' : 'down') + ' sort-icon')
                : 'fa-solid fa-sort sort-icon';
            el.closest('th').classList.toggle('sorted', f === field);
        });

        const tbody = document.getElementById('catTableBody');
        const rows  = allRows();
        rows.sort((a, b) => {
            let va = field === 'id' ? parseInt(a.dataset.id) : a.dataset.name;
            let vb = field === 'id' ? parseInt(b.dataset.id) : b.dataset.name;
            if (va < vb) return dir === 'asc' ? -1 :  1;
            if (va > vb) return dir === 'asc' ?  1 : -1;
            return 0;
        });
        rows.forEach(r => tbody.appendChild(r));
        buildPaging();
    }

    // ── Sıfırla ──
    function resetCatFilters() {
        document.getElementById('catSearch').value = '';
        document.getElementById('sortSelect').value = 'id-asc';
        allRows().forEach(r => r.style.display = '');
        document.getElementById('statFiltered').textContent = allRows().length;
        document.getElementById('emptyState').style.display = 'none';
        sortBy('id', 'asc');
        showToast('Filtreler sıfırlandı.', 'info');
    }

    // ── Basit Pagination ──
    const PAGE_SIZE = 10;
    let currentPage = 1;

    function buildPaging() {
        const visible = allRows().filter(r => r.style.display !== 'none');
        const total   = visible.length;
        const pages   = Math.max(1, Math.ceil(total / PAGE_SIZE));
        if (currentPage > pages) currentPage = pages;

        visible.forEach((r, i) => {
            r.style.display = (i >= (currentPage - 1) * PAGE_SIZE && i < currentPage * PAGE_SIZE) ? '' : 'none';
        });

        // Gizlenenleri gizle (filtered out)
        allRows().filter(r => r.getAttribute('data-hidden') === 'true').forEach(r => r.style.display = 'none');

        const info = document.getElementById('pagingInfo');
        const from = total === 0 ? 0 : (currentPage - 1) * PAGE_SIZE + 1;
        const to   = Math.min(currentPage * PAGE_SIZE, total);
        info.textContent = total > 0 ? `${from}–${to} / toplam ${total} kategori` : '0 kategori';

        const btns = document.getElementById('pagingBtns');
        btns.innerHTML = '';

        // Prev
        const prev = makePageBtn('<i class="fa-solid fa-chevron-left" style="font-size:11px;"></i>', () => goPage(currentPage - 1));
        if (currentPage === 1) prev.disabled = true;
        btns.appendChild(prev);

        for (let p = 1; p <= pages; p++) {
            const btn = makePageBtn(p, () => goPage(p));
            if (p === currentPage) btn.classList.add('active');
            btns.appendChild(btn);
        }

        // Next
        const next = makePageBtn('<i class="fa-solid fa-chevron-right" style="font-size:11px;"></i>', () => goPage(currentPage + 1));
        if (currentPage === pages) next.disabled = true;
        btns.appendChild(next);

        document.getElementById('pagingWrap').style.display = total <= PAGE_SIZE && pages === 1 ? 'none' : 'flex';
    }

    function makePageBtn(html, fn) {
        const b = document.createElement('button');
        b.type = 'button';
        b.className = 'page-btn';
        b.innerHTML = html;
        b.addEventListener('click', fn);
        return b;
    }

    function goPage(p) {
        const visible = allRows().filter(r => r.getAttribute('data-filtered') !== 'false');
        const pages = Math.max(1, Math.ceil(visible.length / PAGE_SIZE));
        currentPage = Math.max(1, Math.min(pages, p));
        buildPaging();
    }

    // ── Modal: Ekle ──
    function openAddModal() {
        document.getElementById('modalTitle').textContent   = 'Yeni Kategori Ekle';
        document.getElementById('modalHeaderIcon').className = 'fa-solid fa-plus';
        document.getElementById('modalSaveBtnText').textContent = 'Kaydet';
        document.getElementById('modalCatId').value   = '0';
        document.getElementById('modalCatName').value = '';
        document.getElementById('modalCatName').classList.remove('is-invalid');
        document.getElementById('modalNameError').style.display = 'none';
        document.getElementById('modalCharCount').textContent   = '0';
        document.getElementById('catModalForm').action = '/Category/Create';
        new bootstrap.Modal(document.getElementById('catModal')).show();
    }

    // ── Modal: Düzenle ──
    function openEditModal(id, name) {
        document.getElementById('modalTitle').textContent   = 'Kategoriyi Düzenle';
        document.getElementById('modalHeaderIcon').className = 'fa-solid fa-pen-to-square';
        document.getElementById('modalSaveBtnText').textContent = 'Güncelle';
        document.getElementById('modalCatId').value   = id;
        document.getElementById('modalCatName').value = name;
        document.getElementById('modalCatName').classList.remove('is-invalid');
        document.getElementById('modalNameError').style.display = 'none';
        document.getElementById('modalCharCount').textContent   = name.length;
        document.getElementById('catModalForm').action = '/Category/Edit';
        new bootstrap.Modal(document.getElementById('catModal')).show();
    }

    // ── Modal: Sil ──
    function openDeleteModal(id, name) {
        document.getElementById('deleteCatName').textContent = `"${name}"`;
        document.getElementById('deleteCatId').value         = id;
        document.getElementById('deleteForm').action         = `/Category/Delete/${id}`;
        new bootstrap.Modal(document.getElementById('deleteModal')).show();
    }

    // ── Modal kaydet ──
    function submitCatModal() {
        const input = document.getElementById('modalCatName');
        const err   = document.getElementById('modalNameError');

        if (!input.value.trim()) {
            input.classList.add('is-invalid');
            err.style.display = 'flex';
            input.focus();
            return;
        }
        input.classList.remove('is-invalid');
        err.style.display = 'none';

        document.getElementById('catModalForm').submit();
    }

    // ── Karakter sayacı ──
    function updateModalCharCount(el) {
        document.getElementById('modalCharCount').textContent = el.value.length;
        if (el.value.trim()) {
            el.classList.remove('is-invalid');
            document.getElementById('modalNameError').style.display = 'none';
        }
    }

    // ── Enter ile modal gönder ──
    document.getElementById('modalCatName')?.addEventListener('keydown', e => {
        if (e.key === 'Enter') { e.preventDefault(); submitCatModal(); }
    });

    // ── İlk yüklemede pagination kur ──
    document.addEventListener('DOMContentLoaded', () => {
        buildPaging();

        // TempData toast mesajı (opsiyonel)
        @if (TempData["Success"] != null)
        {
                <text>showToast('@TempData["Success"]', 'success');</text>
        }
        @if (TempData["Error"] != null)
        {
                <text>showToast('@TempData["Error"]', 'danger');</text>
        }
    });
</script>


